{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": [
    "-lintignore"
  ],
  "ignoreDependencies": [
    "uno.css"
  ],
  "ignoreIssues": {
    "packages/plugin-sdk/**": [
      "exports",
      "types"
    ],
    "packages/core-agent/**": [
      "exports",
      "types"
    ]
  },
  "workspaces": {
    ".": {},
    "apps/stage-tamagotchi": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.ts",
        "src/preload/beat-sync.ts",
        "src/renderer/main.ts",
        "src/renderer/beat-sync.main.ts",
        "src/renderer/pages/**/*.vue",
        "src/renderer/layouts/**/*.vue"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/stage-ui": {
      "entry": [
        "src/**/*.story.vue",
        "stories/setup.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/ui-transitions": {
      "project": [
        "src/**/*.ts",
        "playground/src/**/*.ts"
      ]
    },
    "packages/stage-ui-three": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/plugin-sdk": {
      "project": [
        "src/**/*.ts",
        "!src/**/testdata/**"
      ]
    },
    "packages/core-agent": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/ccc": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/stage-ui-live2d": {
      "entry": [
        "src/utils/live2d-structure-report.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/stage-layouts": {
      "project": [
        "src/**/*.ts"
      ]
    }
  }
}
