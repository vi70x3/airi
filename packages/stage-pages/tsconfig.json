{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "lib": ["DOM", "DOM.AsyncIterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@proj-airi/stage-ui/*": ["../../packages/stage-ui/src/*"],
      "@proj-airi/stage-ui-three/*": ["../../packages/stage-ui-three/src/*"],
      "@proj-airi/stage-ui-live2d/*": ["../../packages/stage-ui-live2d/src/*"],
      "@proj-airi/stage-ui-spine/*": ["../../packages/stage-ui-spine/src/*"],
      "@proj-airi/stage-ui-mmd": ["../../packages/stage-ui-mmd/src/index.ts"],
      "@proj-airi/stage-ui-mmd/*": ["../../packages/stage-ui-mmd/src/*"]
    },
    "resolveJsonModule": true,
    "types": ["vitest", "vite/client", "unplugin-info/client", "@webgpu/types"],
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "vueCompilerOptions": {
    "plugins": ["@vue-macros/volar/define-models", "@vue-macros/volar/define-slots"],
    "skipTemplateCodegen": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "exclude": ["dist", "node_modules"]
}
